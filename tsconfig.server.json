{
  "compilerOptions": {
    "lib": ["esnext"],
    "allowJs": true,
    "skipLibCheck": true,
    "strict": false,
    "esModuleInterop": true,
    "module": "commonjs",
    "moduleResolution": "node",
    "resolveJsonModule": true,
    "isolatedModules": false,
    "jsx": "preserve",
    "target": "es2017",
    "paths": { "@/*": ["./src/*"] }
  },
  "include": ["server.ts", "prisma/seed.ts", "src/lib/**/*.ts", "src/types/**/*.ts"],
  "exclude": ["node_modules", ".next"]
}
