generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           String   @id @default(uuid())
  email        String   @unique
  name         String
  avatarUrl    String?
  vibeLevel    Int      @default(3)
  isAdmin      Boolean  @default(false)
  isOptedOut   Boolean  @default(false)
  registeredAt DateTime @default(now())
  updatedAt    DateTime @updatedAt

  accounts             Account[]
  sessions             Session[]
  teamMembers          TeamMember[]
  triggeredObstacles   ObstacleEvent[]
}

model Account {
  id                String  @id @default(uuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(uuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Project {
  id          String      @id @default(uuid())
  name        String
  tagline     String
  spec        String      @db.Text
  difficulty  Difficulty?
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  assignments TeamAssignment[]
}

enum Difficulty {
  easy
  medium
  hard
}

model TechStack {
  id        String   @id @default(uuid())
  frontend  String
  backend   String
  label     String
  createdAt DateTime @default(now())

  assignments TeamAssignment[]
}

model Obstacle {
  id              String   @id @default(uuid())
  name            String
  icon            String
  description     String   @db.Text
  severity        Severity
  durationMinutes Int      @default(0)
  isCustom        Boolean  @default(false)
  createdAt       DateTime @default(now())

  events ObstacleEvent[]
}

enum Severity {
  low
  medium
  high
  critical
}

model Event {
  id                   String    @id @default(uuid())
  phase                Phase     @default(registration)
  timerDurationSeconds Int       @default(14400)
  timerStartedAt       DateTime?
  timerPausedRemaining Int?
  createdAt            DateTime  @default(now())
  startedAt            DateTime?
  finishedAt           DateTime?

  teams          Team[]
  obstacleEvents ObstacleEvent[]
  eventLog       EventLog[]
}

enum Phase {
  registration
  active
  paused
  finished
}

model Team {
  id             String   @id @default(uuid())
  eventId        String
  name           String
  totalVibeLevel Int      @default(0)
  isSolo         Boolean  @default(false)
  createdAt      DateTime @default(now())

  event      Event          @relation(fields: [eventId], references: [id])
  members    TeamMember[]
  assignment TeamAssignment?
  obstacleTargets ObstacleEvent[] @relation("ObstacleTargets")
}

model TeamMember {
  id     String @id @default(uuid())
  teamId String
  userId String

  team Team @relation(fields: [teamId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id])

  @@unique([teamId, userId])
}

model TeamAssignment {
  id          String   @id @default(uuid())
  teamId      String   @unique
  projectId   String
  techStackId String
  assignedAt  DateTime @default(now())
  swapHistory Json     @default("[]")

  team      Team      @relation(fields: [teamId], references: [id], onDelete: Cascade)
  project   Project   @relation(fields: [projectId], references: [id])
  techStack TechStack @relation(fields: [techStackId], references: [id])
}

model ObstacleEvent {
  id            String        @id @default(uuid())
  eventId       String
  obstacleId    String
  triggeredById String
  triggeredAt   DateTime      @default(now())
  expiresAt     DateTime?
  status        ObstacleStatus @default(active)
  customNote    String?

  event       Event    @relation(fields: [eventId], references: [id])
  obstacle    Obstacle @relation(fields: [obstacleId], references: [id])
  triggeredBy User     @relation(fields: [triggeredById], references: [id])
  targetTeams Team[]   @relation("ObstacleTargets")
}

enum ObstacleStatus {
  active
  resolved
  dismissed
}

model EventLog {
  id        String   @id @default(uuid())
  eventId   String
  message   String
  type      LogType
  timestamp DateTime @default(now())
  metadata  Json?

  event Event @relation(fields: [eventId], references: [id])
}

enum LogType {
  system
  obstacle
  swap
  admin_action
}
