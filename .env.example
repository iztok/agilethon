DATABASE_URL=postgresql://user:password@localhost:5432/agilethon

# Clerk Authentication (https://clerk.com)
# Get these from your Clerk dashboard after creating an app
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_...
CLERK_SECRET_KEY=sk_test_...

# Clerk redirect URLs (can leave as-is)
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/login
NEXT_PUBLIC_CLERK_SIGN_IN_FALLBACK_REDIRECT_URL=/
NEXT_PUBLIC_CLERK_SIGN_UP_FALLBACK_REDIRECT_URL=/

# Domain restriction — only @agiledrop.com emails allowed
ALLOWED_EMAIL_DOMAIN=agiledrop.com
